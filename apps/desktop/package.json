{
  "name": "@kody/desktop",
  "version": "0.1.4",
  "description": "A local-first coding agent workspace powered by Rust and Electron.",
  "author": "Jianliang Wang",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:server:dev": "cargo build --manifest-path ../../Cargo.toml -p kody-app-server",
    "build:server": "cargo build --release --manifest-path ../../Cargo.toml -p kody-app-server",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:server:dev && npm run build && playwright test",
    "package": "npm run build:server && npm run build && electron-builder --dir",
    "dist": "npm run build:server && npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^27.0.1",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "dev.kody.agent",
    "productName": "Kody",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../target/release",
        "to": "bin",
        "filter": [
          "kody-app-server",
          "kody-app-server.exe"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jianliang00",
        "repo": "kody-releases",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Development",
      "target": "AppImage"
    }
  }
}
